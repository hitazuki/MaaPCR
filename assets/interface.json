    "description": "这是pcr日服小助手 MaaPCR。",
    //"contact": "QQ群: 123456789",
    "license": "GPL-3.0",
    "welcome": "首次使用！欢迎使用 MaaPCR!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/hitazuki/MaaPCR",
    "version": "1.0.0",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                //"window_regex": "PrincessConnect",
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "FramePool", // 截图方式
                "mouse": "SendMessage", // 鼠标控制方式
                "keyboard": "SendMessage" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "日服",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
